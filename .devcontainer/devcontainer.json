{
  "name": "A and B Wedding Website",

  "dockerComposeFile": "../docker-compose.yaml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces",

  "forwardPorts": [5000, 5173],
  "portsAttributes": {
    "5000": {
      "label": "Flask Backend",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "React Frontend",
      "onAutoForward": "notify"
    }
  },
  "mounts": [
    "source=project-frontend-node_modules,target=${containerWorkspaceFolder}/services/frontend/node_modules,type=volume",
    "source=project-backend-venv,target=${containerWorkspaceFolder}/services/backend/.venv,type=volume"
  ],
  "remoteEnv": {
    "POETRY_VIRTUALENVS_IN_PROJECT": "true"
  },
  "postCreateCommand": "sudo chown -R vscode:vscode /workspaces/services/frontend/node_modules /workspaces/services/backend/.venv && cd /workspaces/services/frontend && yarn install && cd /workspaces/services/backend && poetry install --no-interaction --no-ansi",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "streetsidesoftware.code-spell-checker",
        "eamodio.gitlens",
        "PKief.material-icon-theme",
        "esbenp.prettier-vscode",
        "rvest.vs-code-prettier-eslint",
        "ms-azuretools.vscode-docker",
        "aaron-bond.better-comments",
        "njpwerner.autodocstring",
        "tamasfe.even-better-toml",
        "william-voyek.vscode-nginx",
        "kevinrose.vsc-python-indent",
        "anthropic.claude-code"
      ]
    }
  }
}
